# Copy this file to .env in the same folder (server/.env):
#   cp .env.example .env
# Then replace the dummy values below with your real settings.

# Port the API listens on (default 4000)
PORT=4000

# MongoDB — pick ONE style:
# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/grace-beauty-studio
# MongoDB Atlas (example — use your own user, password, cluster host):
# MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/grace-beauty-studio?retryWrites=true&w=majority

# Secret for signing admin JWTs — use a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=dummy-jwt-secret-change-this-to-something-long-and-random-abc123xyz

# First admin login for http://localhost:5173/admin (change after first login if you want)
ADMIN_EMAIL=owner@gracebeautystudio.example
ADMIN_PASSWORD=MyDummyPassword123!

# Public site URL (no trailing slash) — used in confirmation emails for “view/cancel” links
# Example dev: http://localhost:5173  |  production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# Resend (https://resend.com) — optional; leave empty to skip confirmation emails in dev
RESEND_API_KEY=re_dummy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender must be verified in Resend. For testing, Resend allows onboarding@resend.dev
EMAIL_FROM=Grace Beauty Studio <onboarding@resend.dev>
