# Copy to `.env` in the repo root for local overrides. Vite reads this at dev/build time.
# For Vercel: set matching values in Project → Settings → Environment Variables.

# --- Client (Vite) — optional ---
# Leave empty when the SPA and API share the same deployment (recommended on Vercel).
# Use the site origin only (no trailing slash, no /api suffix):
# VITE_API_URL=https://your-project.vercel.app

VITE_API_URL=

# --- Server (Express / serverless) — set in Vercel for Production + Preview ---
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dbname
# JWT_SECRET=long-random-string
# FRONTEND_URL=https://your-project.vercel.app
# RESEND_API_KEY=re_...
# EMAIL_FROM=Grace Beauty <bookings@yourdomain.com>
