# Copy this file to .env in the project root (same folder as package.json):
#   cp .env.example .env
#
# In local development you usually do NOT need this file — Vite proxies /api to the API on port 4000.
# Use VITE_API_URL only when the built site is hosted separately from the API (production).

# Leave empty for local dev (uses same origin + Vite proxy to http://localhost:4000)
VITE_API_URL=

# Example for production (no trailing slash):
# VITE_API_URL=https://api.yoursalon.com
MONGODB_URI=mongodb+srv://Grace:Grace@123@grace.zsgqvfd.mongodb.net/?appName=Grace

ADMIN_EMAIL=admin@grace.com
ADMIN_PASSWORD=Grace123!